local BHit = CreateBtn("HIT MULTIPLIER", 50); local BSpd = CreateBtn("TP-WALK", 95); local BEsp = CreateBtn("ESP NAMES", 140); local BHb = CreateBtn("HITBOX: OFF", 185)
local RangoInp = CreateInput("Rango Hitbox (15)", 235); local TargetInp = CreateInput("Clan / Nombre (Ej: _HS)", 275); local SpeedInp = CreateInput("Velocidad TP (2)", 315)
