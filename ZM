-- [[ FUNCIONES LÓGICAS ]] --
local function ClearHB()
    for _, plr in ipairs(game.Players:GetPlayers()) do
        if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            plr.Character.HumanoidRootPart.Size = Vector3.new(2, 2, 1); plr.Character.HumanoidRootPart.Transparency = 1
        end
    end
end

local function ApplyESP(plr)
    local function Create(char)
        if not char then return end
        local head = char:WaitForChild("Head", 10)
        local h = Instance.new("Highlight", char); h.Name = "ZM_High"; h.FillColor = Color3.new(1, 0, 0)
        local b = Instance.new("BillboardGui", char); b.Name = "ZM_Tag"; b.Size = UDim2.new(0, 200, 0, 50); b.Adornee = head; b.AlwaysOnTop = true; b.ExtentsOffset = Vector3.new(0, 3, 0)
        local l = Instance.new("TextLabel", b); l.Size = UDim2.new(1, 0, 1, 0); l.BackgroundTransparency = 1; l.Text = plr.Name; l.TextColor3 = Color3.new(1, 1, 1); l.Font = Enum.Font.GothamBold; l.TextSize = 12
        RunService.RenderStepped:Connect(function() if char and char.Parent then h.Enabled = ZM_Settings.Esp l.Visible = ZM_Settings.Esp end end)
    end
    plr.CharacterAdded:Connect(Create); if plr.Character then Create(plr.Character) end
end

local function Sync()
    local on, off = Color3.fromRGB(0, 160, 0), Color3.fromRGB(160, 0, 0)
    BHit.BackgroundColor3 = ZM_Settings.Hit and on or off; QHit.BackgroundColor3 = ZM_Settings.Hit and on or off
    BSpd.BackgroundColor3 = ZM_Settings.Spd and on or off; QSpd.BackgroundColor3 = ZM_Settings.Spd and on or off
    BEsp.BackgroundColor3 = ZM_Settings.Esp and on or off; QEsp.BackgroundColor3 = ZM_Settings.Esp and on or off
    BHb.BackgroundColor3 = ZM_Settings.HbActivo and on or off; QHb.BackgroundColor3 = ZM_Settings.HbActivo and on or off; BHb.Text = ZM_Settings.HbActivo and "HITBOX: ON" or "HITBOX: OFF"
end

-- EVENTOS
BHit.MouseButton1Click:Connect(function() ZM_Settings.Hit = not ZM_Settings.Hit Sync() end)
QHit.MouseButton1Click:Connect(function() ZM_Settings.Hit = not ZM_Settings.Hit Sync() end)
BSpd.MouseButton1Click:Connect(function() ZM_Settings.Spd = not ZM_Settings.Spd Sync() end)
QSpd.MouseButton1Click:Connect(function() ZM_Settings.Spd = not ZM_Settings.Spd Sync() end)
BEsp.MouseButton1Click:Connect(function() ZM_Settings.Esp = not ZM_Settings.Esp Sync() end)
QEsp.MouseButton1Click:Connect(function() ZM_Settings.Esp = not ZM_Settings.Esp Sync() end)
BHb.MouseButton1Click:Connect(function() ZM_Settings.HbActivo = not ZM_Settings.HbActivo if not ZM_Settings.HbActivo then ClearHB() end Sync() end)
QHb.MouseButton1Click:Connect(function() ZM_Settings.HbActivo = not ZM_Settings.HbActivo if not ZM_Settings.HbActivo then ClearHB() end Sync() end)

Close.MouseButton1Click:Connect(function() Main.Visible = false; TopBar.Visible = true end)
ZMBtn.MouseButton1Click:Connect(function() Main.Visible = true; TopBar.Visible = false end)

RangoInp.FocusLost:Connect(function() ZM_Settings.HbRango = tonumber(RangoInp.Text) or 15 end)
TransInp.FocusLost:Connect(function() ZM_Settings.HbTrans = tonumber(TransInp.Text) or 0.8 end)
SpeedInp.FocusLost:Connect(function() ZM_Settings.Val = tonumber(SpeedInp.Text) or 2 end)
TargetInp.FocusLost:Connect(function() ZM_Settings.HbObj = TargetInp.Text:lower() ~= "" and TargetInp.Text:lower() or "todos" end)

for _, v in pairs(game.Players:GetPlayers()) do if v ~= p then ApplyESP(v) end end
game.Players.PlayerAdded:Connect(function(v) if v ~= p then ApplyESP(v) end end)

-- [[ LOOPS DE FUNCIONAMIENTO ]] --
RunService.RenderStepped:Connect(function()
    if ZM_Settings.Spd and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
        local hum = p.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.MoveDirection.Magnitude > 0 then
            p.Character.HumanoidRootPart.CFrame = p.Character.HumanoidRootPart.CFrame + (hum.MoveDirection * (ZM_Settings.Val / 10))
        end
    end
end)

task.spawn(function()
    while task.wait(0.1) do
        if ZM_Settings.HbActivo then
            for _, plr in ipairs(game.Players:GetPlayers()) do
                if plr ~= p and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = plr.Character.HumanoidRootPart
                    local n = plr.Name:lower()
                    if ZM_Settings.HbObj == "todos" or n:find(ZM_Settings.HbObj) then
                        hrp.Size = Vector3.new(ZM_Settings.HbRango, ZM_Settings.HbRango, ZM_Settings.HbRango)
                        hrp.Transparency = ZM_Settings.HbTrans; hrp.BrickColor = BrickColor.new("Cyan"); hrp.CanCollide = false
                    else hrp.Size = Vector3.new(2, 2, 1); hrp.Transparency = 1 end
                end
            end
        end
    end
end)

Sync()
