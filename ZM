-- [[ ESP UNIVERSAL ]] --
local function CreateESP(plr)
    if plr == p then return end
    local function Setup(char)
        if not char then return end
        local head = char:WaitForChild("Head", 15)
        if not head then return end
        if head:FindFirstChild("ZM_Tag") then head.ZM_Tag:Destroy() end
        local bg = Instance.new("BillboardGui", head); bg.Name = "ZM_Tag"; bg.Size = UDim2.new(0, 200, 0, 50); bg.AlwaysOnTop = true; bg.ExtentsOffset = Vector3.new(0, 3, 0)
        local tl = Instance.new("TextLabel", bg); tl.Size = UDim2.new(1, 0, 1, 0); tl.BackgroundTransparency = 1; tl.TextColor3 = PinkMain; tl.TextStrokeColor3 = Black; tl.TextStrokeTransparency = 0; tl.Font = Enum.Font.GothamBold; tl.TextSize = 14
        local connection
        connection = RunService.RenderStepped:Connect(function()
            if char and char.Parent and head and head.Parent and _G.ZM_Settings.Esp then
                local obj = _G.ZM_Settings.HbObj
                if obj == "todos" or plr.Name:lower():find(obj) then tl.Visible = true; tl.Text = plr.Name else tl.Visible = false end
            else
                tl.Visible = false
                if not char or not char.Parent then connection:Disconnect() end
            end
        end)
    end
    plr.CharacterAdded:Connect(Setup)
    if plr.Character then task.spawn(Setup, plr.Character) end
end

-- [[ LOOP HITBOX OPTIMIZADO ]] --
task.spawn(function()
    while task.wait(0.3) do
        if _G.ZM_Settings.HbActivo then
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= p and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = plr.Character.HumanoidRootPart
                    local n = plr.Name:lower()
                    if _G.ZM_Settings.HbObj == "todos" or n:find(_G.ZM_Settings.HbObj) then
                        hrp.Size = Vector3.new(_G.ZM_Settings.HbRango, _G.ZM_Settings.HbRango, _G.ZM_Settings.HbRango)
                        hrp.Transparency = _G.ZM_Settings.HbTrans
                        hrp.Color = CelesteHb
                        hrp.CanCollide = false
                    else
                        hrp.Size = Vector3.new(2, 2, 1)
                        hrp.Transparency = 1
                    end
                end
            end
        end
    end
end)

for _, plr in ipairs(Players:GetPlayers()) do CreateESP(plr) end
Players.PlayerAdded:Connect(CreateESP)
Sync()
