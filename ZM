-- [[ ZM HUB - VERSIÓN FINAL INTEGRADA (V135) ]] --
local p = game:GetService("Players").LocalPlayer
local UI_NAME = "ZM_FINAL_FIX"
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

if CoreGui:FindFirstChild(UI_NAME) then CoreGui[UI_NAME]:Destroy() end

local ZM_Settings = { 
    Hit = false, Spd = false, Esp = false, Val = 2,
    repeatamount = 50, 
    HbActivo = false, HbRango = 15, HbTrans = 0.8, HbObj = "todos",
    Ignore = {"Block", "Bloque", "Grab", "Agarrar", "Charge", "Carga", "Heavy", "Dash"}
}

-- [[ MOTOR DE COMBATE 50 ]] --
local mt = getrawmetatable(game)
local old = mt.__namecall
setreadonly(mt, false)
mt.__namecall = newcclosure(function(uh, ...)
    local method = getnamecallmethod()
    local args = {...}
    local name = tostring(uh)
    if ZM_Settings.Hit and (method == "FireServer" or method == "InvokeServer") then
        local esAccionBase = false
        for _, word in ipairs(ZM_Settings.Ignore) do if name:find(word) then esAccionBase = true break end end
        if not esAccionBase then
            for i = 1, 25 do old(uh, unpack(args)) end
            task.spawn(function() RunService.Heartbeat:Wait() for i = 1, 25 do old(uh, unpack(args)) end end)
        end
    end
    return old(uh, ...)
end)
setreadonly(mt, true)

-- [[ INTERFAZ ]] --
