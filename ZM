-- [[ MOTOR DE COMBATE: 26 + 40 ]] --
local mt = getrawmetatable(game)
local old = mt.__namecall
setreadonly(mt, false)
mt.__namecall = newcclosure(function(uh, ...)
    local method = getnamecallmethod()
    local args = {...}
    local name = tostring(uh)
    if _G.ZM_Settings.Hit and (method == "FireServer" or method == "InvokeServer") then
        local esAccionBase = false
        for _, word in ipairs(_G.ZM_Settings.Ignore) do if name:find(word) then esAccionBase = true break end end
        if not esAccionBase and (name:find("Hit") or name:find("Punch") or name:find("Attack") or name:find("Combat")) then
            for i = 1, 26 do old(uh, unpack(args)) end
            task.spawn(function()
                for i = 1, 40 do old(uh, unpack(args)) end
            end)
            return old(uh, ...)
        end
    end
    return old(uh, ...)
end)
setreadonly(mt, true)

