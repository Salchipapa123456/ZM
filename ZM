local OpenBtn = Instance.new("TextButton", TopBar); OpenBtn.Size = UDim2.new(0, 50, 0, 25); OpenBtn.Text = "ZM"; OpenBtn.BackgroundColor3 = PinkMain; OpenBtn.TextColor3 = Black; OpenBtn.Font = Enum.Font.GothamBold; Instance.new("UICorner", OpenBtn)

