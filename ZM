RangoInp.FocusLost:Connect(function() _G.ZM_Settings.HbRango = tonumber(RangoInp.Text) or 15 end)
TargetInp.FocusLost:Connect(function() _G.ZM_Settings.HbObj = TargetInp.Text:lower() ~= "" and TargetInp.Text:lower() or "todos" end)
SpeedInp.FocusLost:Connect(function() _G.ZM_Settings.Val = tonumber(SpeedInp.Text) or 2 end)

-- [[ ESP MEJORADO ]] --
local function CreateESP(plr)
    local function Setup(char)
        if not char then return end
        local head = char:WaitForChild("Head", 10)
        local bg = Instance.new("BillboardGui", head); bg.Name = "ZM_Tag"; bg.Size = UDim2.new(0, 200, 0, 50); bg.AlwaysOnTop = true; bg.ExtentsOffset = Vector3.new(0, 3, 0)
        local tl = Instance.new("TextLabel", bg); tl.Size = UDim2.new(1, 0, 1, 0); tl.BackgroundTransparency = 1
        tl.TextColor3 = PinkMain; tl.TextStrokeColor3 = Black; tl.TextStrokeTransparency = 0; tl.Font = Enum.Font.GothamBold; tl.TextSize = 14

        RunService.RenderStepped:Connect(function()
            if char and char.Parent and _G.ZM_Settings.Esp then
                local n = plr.Name:lower()
                if _G.ZM_Settings.HbObj == "todos" or n:find(_G.ZM_Settings.HbObj) then
                    tl.Visible = true; tl.Text = plr.Name
                else tl.Visible = false end
            else tl.Visible = false end
        end)
    end
    plr.CharacterAdded:Connect(Setup); if plr.Character then Setup(plr.Character) end
end

-- LOOPS
RunService.Stepped:Connect(function()
    if _G.ZM_Settings.Spd and p.Character then
        local hrp = p.Character:FindFirstChild("HumanoidRootPart")
        local hum = p.Character:FindFirstChildOfClass("Humanoid")
        if hrp and hum and hum.MoveDirection.Magnitude > 0 then
            hrp.CFrame = hrp.CFrame + (hum.MoveDirection * (_G.ZM_Settings.Val / 8))
        end
    end
end)

task.spawn(function()
    while task.wait(0.3) do
        if _G.ZM_Settings.HbActivo then
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= p and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = plr.Character.HumanoidRootPart
                    local n = plr.Name:lower()
                    if _G.ZM_Settings.HbObj == "todos" or n:find(_G.ZM_Settings.HbObj) then
                        hrp.Size = Vector3.new(_G.ZM_Settings.HbRango, _G.ZM_Settings.HbRango, _G.ZM_Settings.HbRango)
                        hrp.Transparency = _G.ZM_Settings.HbTrans; hrp.Color = PinkMain; hrp.CanCollide = false
                    else
                        hrp.Size = Vector3.new(2, 2, 1); hrp.Transparency = 1
                    end
                end
            end
        end
    end
end)

for _, plr in pairs(Players:GetPlayers()) do if plr ~= p then CreateESP(plr) end end
Players.PlayerAdded:Connect(CreateESP)
Sync()
