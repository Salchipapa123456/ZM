-- [[ ZM PINK HUB - V153 CLEAN HITBOX & CLAN FIX ]] --
local Players = game:GetService("Players")
local p = Players.LocalPlayer
local UI_NAME = "ZM_PINK_V153"
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

-- WHITELIST
local WhitelistIDs = {8489548981, 10805769723}
local autorizado = false
for _, id in ipairs(WhitelistIDs) do if p.UserId == id then autorizado = true break end end
if not autorizado then return end

p:SetAttribute("ZM_User", true)
if CoreGui:FindFirstChild(UI_NAME) then CoreGui[UI_NAME]:Destroy() end

_G.ZM_Settings = { 
    Hit = false, Spd = false, Esp = false, Val = 2,
    HbActivo = false, HbRango = 15, HbTrans = 0.8, HbObj = "todos",
    Ignore = {"Block", "Bloque", "Grab", "Agarrar", "Charge", "Carga", "Heavy", "Dash"}
}

local PinkMain = Color3.fromRGB(255, 105, 180) 
local PinkLight = Color3.fromRGB(255, 182, 193)
local Black = Color3.fromRGB(0, 0, 0)

-- [[ MOTOR DE COMBATE: 25 + 35 ACUMULATIVO ]] --
local mt = getrawmetatable(game)
local old = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(uh, ...)
    local method = getnamecallmethod()
    local args = {...}
    local name = tostring(uh)
    
    if _G.ZM_Settings.Hit and (method == "FireServer" or method == "InvokeServer") then
        local esAccionBase = false
        for _, word in ipairs(_G.ZM_Settings.Ignore) do if name:find(word) then esAccionBase = true break end end
        
        if not esAccionBase and (name:find("Hit") or name:find("Punch") or name:find("Attack")) then
            for i = 1, 25 do old(uh, unpack(args)) end
            task.spawn(function()
                RunService.Heartbeat:Wait()
                for i = 1, 35 do old(uh, unpack(args)) end
            end)
            return old(uh, ...)
        end
    end
    return old(uh, ...)
end)
setreadonly(mt, true)

