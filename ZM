local BHit = MainBtn("HIT MULTIPLIER", 40); local BSpd = MainBtn("TP-WALK", 80); local BEsp = MainBtn("ESP NAMES", 120); local BHb = MainBtn("HITBOX: OFF", 160)
local RangoInp = CreateInput("Rango Hitbox (15)", 200); local TransInp = CreateInput("Transparencia (0.8)", 235); local TargetInp = CreateInput("Objetivo (Nombre)", 270); local SpeedInp = CreateInput("Velocidad TP (2)", 310)

