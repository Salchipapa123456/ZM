-- [[ TP-WALK CON TRANSLATEBY EN STEPPED ]] --
RunService.Stepped:Connect(function()
    if _G.ZM_Settings.Spd and p.Character then
        local hum = p.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.Parent and hum.MoveDirection.Magnitude > 0 then
            p.Character:TranslateBy(hum.MoveDirection * (tonumber(_G.ZM_Settings.Val) or 2))
        end
    end
end)

-- [[ LIMPIEZA FORZOSA DE HITBOX ]] --
local function ClearHB()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= p and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = plr.Character.HumanoidRootPart
            hrp.Size = Vector3.new(2, 2, 1)
            hrp.Transparency = 1
            hrp.CanCollide = true -- Volver a colisión normal
        end
    end
end

