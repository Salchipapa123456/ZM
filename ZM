local QHit = QuickBtn("HIT", 55); local QSpd = QuickBtn("SPD", 105); local QEsp = QuickBtn("ESP", 155); local QHb = QuickBtn("HB", 205)

-- [[ FUNCIÓN LIMPIEZA DE HITBOX ]] --
local function ClearHB()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= p and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = plr.Character.HumanoidRootPart
            hrp.Size = Vector3.new(2, 2, 1)
            hrp.Transparency = 1
            hrp.CanCollide = true
        end
    end
end

local function Sync()
    local on, off = PinkMain, PinkLight
    BHit.BackgroundColor3 = _G.ZM_Settings.Hit and on or off; QHit.BackgroundColor3 = _G.ZM_Settings.Hit and on or off
    BSpd.BackgroundColor3 = _G.ZM_Settings.Spd and on or off; QSpd.BackgroundColor3 = _G.ZM_Settings.Spd and on or off
    BEsp.BackgroundColor3 = _G.ZM_Settings.Esp and on or off; QEsp.BackgroundColor3 = _G.ZM_Settings.Esp and on or off
    BHb.BackgroundColor3 = _G.ZM_Settings.HbActivo and on or off; QHb.BackgroundColor3 = _G.ZM_Settings.HbActivo and on or off
    BHb.Text = _G.ZM_Settings.HbActivo and "HITBOX: ON" or "HITBOX: OFF"
end

